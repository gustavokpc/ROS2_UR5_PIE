0.20916268229484558 -0.17228952050209045 0.45584991574287415 0.8487652540206909 0.10017430782318115 -0.8034543991088867 0.8127628564834595
];

N = size(robot_poses,1);
T_bc_all = zeros(4,4,N);

for i = 1:N
    
    %% --------- ROBOT (base -> gripper) ----------
    pose_r = robot_poses(i,:);
    
    rz = pose_r(1);
    ry = pose_r(2);
    rx = pose_r(3);
    
    t_r = pose_r(4:6)';
    
    % rotação ZYX
    Rz = [cos(rz) -sin(rz) 0;
          sin(rz)  cos(rz) 0;
          0        0       1];
      
    Ry = [cos(ry) 0 sin(ry);
          0       1 0;
         -sin(ry) 0 cos(ry)];
     
    Rx = [1 0 0;
          0 cos(rx) -sin(rx);
          0 sin(rx)  cos(rx)];
    
    R_r = Rz * Ry * Rx;

    R_r = eul2rotm([rz ry rx], 'ZYX');
    
    T_bg = [R_r, t_r; 0 0 0 1];
    
    %% --------- CAGE (cage -> gripper) ----------
    pose_c = cage_poses(i,:);
    
    q = pose_c(1:4); % [qx qy qz qw]
    t_c = pose_c(5:7)';
    
    R_c = quat2rotm(q); % MATLAB padrão
    
    T_cg = [R_c, t_c; 0 0 0 1];
    
    
    %% --------- BASE -> CAGE ----------
    T_bc_all(:,:,i) = T_bg / T_cg;
end


%% --------- MÉDIA ----------

% média da translação
t = mean(T_bc_all(1:3,4,:),3);

% média da rotação (SVD)
R_sum = zeros(3);
for i = 1:N
    R_sum = R_sum + T_bc_all(1:3,1:3,i);
end

[U,~,V] = svd(R_sum);
R = U*V';

T_bc = [R, t; 0 0 0 1];

disp('Transformacao base -> cage:')
disp(T_bc)


%% --------- VALIDAÇÃO ----------
err = 0;

for i = 1:N
    T_bg = T_bc * T_cg; % reconstrução
    err = err + norm(T_bg - T_bc_all(:,:,i));
end

disp(['Erro medio: ', num2str(err/N)]);